# Copy to .env and edit. Everything has a working default (offline/test mode).

# --- LLM: test (default, keyless) | openai | anthropic | ollama ---
llm_provider=test
llm_model=gpt-4o-mini
# openai_api_key=sk-...
# anthropic_api_key=sk-ant-...
# ollama_host=http://localhost:11434

# --- Embeddings: fastembed (default, local BGE) | openai ---
embedding_provider=fastembed
embedding_model=BAAI/bge-small-en-v1.5

# --- Qdrant: empty => local on-disk; set URL for server/docker ---
# qdrant_url=http://localhost:6333
qdrant_path=./data/qdrant
collection=support_docs

# --- Retrieval tuning (calibrated for BGE-small) ---
top_k=5
bm25_floor=4.5
dense_floor=0.65
